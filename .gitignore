# --- System & IDE Cache ---
.DS_Store
.vscode/
.idea/
*.log

# --- Python / FastAPI Backend Cache ---
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
.pytest_cache/
.env
*.db
*.sqlite3

# --- React Frontend Dependencies & Builds ---
frontend/node_modules/
frontend/dist/
frontend/.env.local
frontend/.env.development.local
frontend/.env.production.local

# --- Container / Volume Data (Crucial!) ---
# Prevents committing live PostgreSQL data blocks to Git
pgdata/
.storage/